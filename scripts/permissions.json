{
  "groups": [
    {
      "comment": "Shell utilities/navigation",
      "rules": [
        { "pattern": "atuin *", "action": "allow" },
        { "pattern": "exit *", "action": "allow" },
        { "pattern": "zoxide *", "action": "allow" }
      ]
    },
    {
      "comment": "Git",
      "rules": [
        { "pattern": "git *", "action": "allow" }
      ]
    },
    {
      "comment": "File and search utilities",
      "rules": [
        { "pattern": "cat *", "action": "allow" },
        { "pattern": "find *", "action": "allow" },
        { "pattern": "find * -delete*", "action": "ask" },
        { "pattern": "find * -exec*", "action": "ask" },
        { "pattern": "find * -execdir*", "action": "ask" },
        { "pattern": "find * -ok*", "action": "ask" },
        { "pattern": "find * -okdir*", "action": "ask" },
        { "pattern": "grep *", "action": "allow" },
        { "pattern": "head *", "action": "allow" },
        { "pattern": "ls *", "action": "allow" },
        { "pattern": "rg *", "action": "allow" },
        { "pattern": "tail *", "action": "allow" }
      ]
    },
    {
      "comment": "Text processing",
      "rules": [
        { "pattern": "awk *", "action": "allow" },
        { "pattern": "column *", "action": "allow" },
        { "pattern": "comm *", "action": "allow" },
        { "pattern": "cut *", "action": "allow" },
