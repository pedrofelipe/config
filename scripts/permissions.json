        { "pattern": "sed * --in-place*", "action": "ask" },
        { "pattern": "sort *", "action": "allow" },
        { "pattern": "tee *", "action": "allow" },
        { "pattern": "tr *", "action": "allow" },
        { "pattern": "uniq *", "action": "allow" },
        { "pattern": "wc *", "action": "allow" },
        { "pattern": "xargs *", "action": "ask" }
