{
  "groups": [
    {
      "comment": "Default",
      "rules": [
        { "pattern": "*", "action": "allow" }
      ]
    },
    {
      "comment": "File deletion",
      "rules": [
        { "pattern": "rm *", "action": "ask" },
        { "pattern": "rm -rf *", "action": "ask" },
        { "pattern": "rsync --del*", "action": "ask" },
        { "pattern": "rsync * --del*", "action": "ask" },
        { "pattern": "find * -delete*", "action": "ask" },
        { "pattern": "find * -exec*", "action": "ask" },
        { "pattern": "find * -execdir*", "action": "ask" },
        { "pattern": "find * -ok*", "action": "ask" },
        { "pattern": "find * -okdir*", "action": "ask" }
      ]
    },
    {
      "comment": "In-place/bulk edits",
      "rules": [
        { "pattern": "sed -i*", "action": "ask" },
        { "pattern": "sed * -i*", "action": "ask" },
        { "pattern": "sed --in-place*", "action": "ask" },
        { "pattern": "sed * --in-place*", "action": "ask" },
        { "pattern": "xargs *", "action": "ask" }
      ]
    },
    {
      "comment": "Git working-tree discards",
      "rules": [
        { "pattern": "git checkout", "action": "ask" },
        { "pattern": "git checkout *", "action": "ask" },
        { "pattern": "git restore", "action": "ask" },
        { "pattern": "git restore *", "action": "ask" },
        { "pattern": "git switch --discard-changes*", "action": "ask" },
        { "pattern": "git switch * --discard-changes*", "action": "ask" },
        { "pattern": "git switch --force*", "action": "ask" },
        { "pattern": "git switch * --force*", "action": "ask" },
        { "pattern": "git clean", "action": "ask" },
        { "pattern": "git clean *", "action": "ask" },
        { "pattern": "git reset", "action": "ask" },
        { "pattern": "git reset *", "action": "ask" },
        { "pattern": "git stash drop*", "action": "ask" },
        { "pattern": "git stash clear*", "action": "ask" },
        { "pattern": "git worktree remove -f*", "action": "ask" },
        { "pattern": "git worktree remove --force*", "action": "ask" },
        { "pattern": "git worktree remove * -f*", "action": "ask" },
        { "pattern": "git worktree remove * --force*", "action": "ask" }
      ]
    },
    {
      "comment": "Git history rewriting",
      "rules": [
        { "pattern": "git rebase", "action": "ask" },
        { "pattern": "git rebase *", "action": "ask" },
        { "pattern": "git commit --amend*", "action": "ask" },
        { "pattern": "git commit * --amend*", "action": "ask" },
        { "pattern": "git filter-branch*", "action": "ask" },
        { "pattern": "git reflog expire*", "action": "ask" },
        { "pattern": "git gc --prune*", "action": "ask" },
        { "pattern": "git update-ref -d*", "action": "ask" },
        { "pattern": "git update-ref --stdin*", "action": "ask" },
        { "pattern": "git prune*", "action": "ask" }
      ]
    },
    {
      "comment": "Git branch/tag deletion",
      "rules": [
        { "pattern": "git branch -d *", "action": "ask" },
        { "pattern": "git branch -D *", "action": "ask" },
        { "pattern": "git branch -f*", "action": "ask" },
        { "pattern": "git branch -M *", "action": "ask" },
        { "pattern": "git branch --delete *", "action": "ask" },
        { "pattern": "git branch --delete --force *", "action": "ask" },
        { "pattern": "git branch --force*", "action": "ask" },
        { "pattern": "git tag -d *", "action": "ask" },
        { "pattern": "git tag --delete *", "action": "ask" },
        { "pattern": "git tag -f*", "action": "ask" }
      ]
    },
    {
      "comment": "Git push",
      "rules": [
        { "pattern": "git push", "action": "ask" },
        { "pattern": "git push *", "action": "ask" },
        { "pattern": "git -C * push*", "action": "ask" },
        { "pattern": "git -c * push*", "action": "ask" }
      ]
    },
    {
      "comment": "Git side effects",
      "rules": [
        { "pattern": "git diff --output*", "action": "ask" },
        { "pattern": "git diff * --output*", "action": "ask" },
        { "pattern": "git diff --ext-diff*", "action": "ask" },
        { "pattern": "git diff * --ext-diff*", "action": "ask" },
        { "pattern": "git config alias.*", "action": "ask" },
        { "pattern": "git config * alias.*", "action": "ask" }
      ]
    },
    {
      "comment": "Dependency changes (pnpm)",
      "rules": [
        { "pattern": "pnpm add*", "action": "ask" },
        { "pattern": "pnpm install*", "action": "ask" },
        { "pattern": "pnpm i", "action": "ask" },
        { "pattern": "pnpm i *", "action": "ask" },
        { "pattern": "pnpm remove*", "action": "ask" },
        { "pattern": "pnpm rm*", "action": "ask" },
        { "pattern": "pnpm uninstall*", "action": "ask" },
        { "pattern": "pnpm un*", "action": "ask" },
        { "pattern": "pnpm link*", "action": "ask" },
        { "pattern": "pnpm unlink*", "action": "ask" },
        { "pattern": "pnpm patch*", "action": "ask" },
        { "pattern": "pnpm patch-commit*", "action": "ask" },
        { "pattern": "pnpm import*", "action": "ask" },
        { "pattern": "pnpm rebuild*", "action": "ask" },
        { "pattern": "pnpm install-test*", "action": "ask" },
        { "pattern": "pnpm it*", "action": "ask" },
        { "pattern": "pnpm update*", "action": "ask" },
        { "pattern": "pnpm up*", "action": "ask" },
        { "pattern": "pnpm upgrade*", "action": "ask" },
        { "pattern": "pnpm fetch*", "action": "ask" },
        { "pattern": "pnpm create*", "action": "ask" },
        { "pattern": "pnpm dlx*", "action": "ask" },
        { "pattern": "pnpm publish*", "action": "ask" },
        { "pattern": "pnpm stage*", "action": "ask" },
        { "pattern": "pnpm deploy*", "action": "ask" },
        { "pattern": "pnpm approve-builds*", "action": "ask" },
        { "pattern": "pnpm self-update*", "action": "ask" },
        { "pattern": "pnpm store add*", "action": "ask" },
        { "pattern": "pnpm store prune*", "action": "ask" },
        { "pattern": "pnpm cache delete*", "action": "ask" },
        { "pattern": "pnpm config set*", "action": "ask" },
        { "pattern": "pnpm config delete*", "action": "ask" },
        { "pattern": "pnpm env add*", "action": "ask" },
        { "pattern": "pnpm env remove*", "action": "ask" },
        { "pattern": "pnpm env use*", "action": "ask" },
        { "pattern": "pnpm runtime add*", "action": "ask" },
        { "pattern": "pnpm runtime remove*", "action": "ask" },
        { "pattern": "pnpm runtime use*", "action": "ask" },
        { "pattern": "pnpm rt add*", "action": "ask" },
        { "pattern": "pnpm rt remove*", "action": "ask" },
        { "pattern": "pnpm rt use*", "action": "ask" }
      ]
    },
    {
      "comment": "Dependency changes (npm)",
      "rules": [
        { "pattern": "npm install*", "action": "ask" },
        { "pattern": "npm i", "action": "ask" },
        { "pattern": "npm i *", "action": "ask" },
        { "pattern": "npm add*", "action": "ask" },
        { "pattern": "npm ci*", "action": "ask" },
        { "pattern": "npm it*", "action": "ask" },
        { "pattern": "npm init *", "action": "ask" },
        { "pattern": "npm create*", "action": "ask" },
        { "pattern": "npm uninstall*", "action": "ask" },
        { "pattern": "npm remove*", "action": "ask" },
        { "pattern": "npm rm*", "action": "ask" },
        { "pattern": "npm un*", "action": "ask" },
        { "pattern": "npm update*", "action": "ask" },
        { "pattern": "npm up*", "action": "ask" },
        { "pattern": "npm link*", "action": "ask" },
        { "pattern": "npm unlink*", "action": "ask" },
        { "pattern": "npm publish*", "action": "ask" },
        { "pattern": "npm audit fix*", "action": "ask" },
        { "pattern": "npm exec*", "action": "ask" },
        { "pattern": "npx *", "action": "ask" }
      ]
    },
    {
      "comment": "Dependency changes (yarn)",
      "rules": [
        { "pattern": "yarn", "action": "ask" },
        { "pattern": "yarn install*", "action": "ask" },
        { "pattern": "yarn add*", "action": "ask" },
        { "pattern": "yarn create*", "action": "ask" },
        { "pattern": "yarn remove*", "action": "ask" },
        { "pattern": "yarn up*", "action": "ask" },
        { "pattern": "yarn dlx*", "action": "ask" },
        { "pattern": "yarn global*", "action": "ask" },
        { "pattern": "yarn link*", "action": "ask" },
        { "pattern": "yarn unlink*", "action": "ask" },
        { "pattern": "yarn publish*", "action": "ask" },
        { "pattern": "yarn npm publish*", "action": "ask" },
        { "pattern": "yarn set version*", "action": "ask" }
      ]
    },
    {
      "comment": "Dependency changes (Python/Ruby)",
      "rules": [
        { "pattern": "pip install*", "action": "ask" },
        { "pattern": "pip uninstall*", "action": "ask" },
        { "pattern": "pip3 install*", "action": "ask" },
        { "pattern": "pip3 uninstall*", "action": "ask" },
        { "pattern": "gem install*", "action": "ask" },
        { "pattern": "gem uninstall*", "action": "ask" },
        { "pattern": "gem update*", "action": "ask" }
      ]
    },
    {
      "comment": "Cloudflare Wrangler CLI",
      "rules": [
        { "pattern": "wrangler", "action": "ask" },
        { "pattern": "wrangler *", "action": "ask" },
        { "pattern": "pnpm exec wrangler*", "action": "ask" }
      ]
    },
    {
      "comment": "Remote state (GitHub)",
      "rules": [
        { "pattern": "gh issue close *", "action": "ask" },
        { "pattern": "gh pr close *", "action": "ask" },
        { "pattern": "gh pr create *", "action": "ask" },
        { "pattern": "gh pr edit *", "action": "ask" },
        { "pattern": "gh pr comment *", "action": "ask" },
        { "pattern": "gh pr review *", "action": "ask" },
        { "pattern": "gh pr ready *", "action": "ask" },
        { "pattern": "gh pr reopen *", "action": "ask" },
        { "pattern": "gh pr merge *", "action": "ask" },
        { "pattern": "gh repo delete *", "action": "ask" },
        { "pattern": "gh release delete*", "action": "ask" },
        { "pattern": "gh run cancel *", "action": "ask" },
        { "pattern": "gh run rerun *", "action": "ask" },
        { "pattern": "gh workflow run *", "action": "ask" },
        { "pattern": "gh workflow enable *", "action": "ask" },
        { "pattern": "gh workflow disable *", "action": "ask" },
        { "pattern": "gh api -X*", "action": "ask" },
        { "pattern": "gh api * -X*", "action": "ask" },
        { "pattern": "gh api --method*", "action": "ask" },
        { "pattern": "gh api * --method*", "action": "ask" },
        { "pattern": "gh api * -f*", "action": "ask" },
        { "pattern": "gh api * -F*", "action": "ask" },
        { "pattern": "gh api * --field*", "action": "ask" },
        { "pattern": "gh api * --raw-field*", "action": "ask" },
        { "pattern": "gh api * --input*", "action": "ask" }
      ]
    },
    {
      "comment": "Remote state (GitLab)",
      "rules": [
        { "pattern": "glab ci cancel *", "action": "ask" },
        { "pattern": "glab ci retry *", "action": "ask" },
        { "pattern": "glab ci run *", "action": "ask" },
        { "pattern": "glab issue close *", "action": "ask" },
        { "pattern": "glab mr close *", "action": "ask" },
        { "pattern": "glab mr create *", "action": "ask" },
        { "pattern": "glab mr update *", "action": "ask" },
        { "pattern": "glab mr note *", "action": "ask" },
        { "pattern": "glab mr approve *", "action": "ask" },
        { "pattern": "glab mr reopen *", "action": "ask" },
        { "pattern": "glab mr merge *", "action": "ask" },
        { "pattern": "glab repo delete *", "action": "ask" },
        { "pattern": "glab api -X*", "action": "ask" },
        { "pattern": "glab api * -X*", "action": "ask" },
        { "pattern": "glab api --method*", "action": "ask" },
        { "pattern": "glab api * --method*", "action": "ask" }
      ]
    },
    {
      "comment": "Homebrew",
      "rules": [
        { "pattern": "brew install *", "action": "ask" },
        { "pattern": "brew install --cask *", "action": "ask" },
        { "pattern": "brew reinstall *", "action": "ask" },
        { "pattern": "brew upgrade*", "action": "ask" },
        { "pattern": "brew tap *", "action": "ask" },
        { "pattern": "brew uninstall *", "action": "ask" },
        { "pattern": "brew remove *", "action": "ask" },
        { "pattern": "brew rm *", "action": "ask" }
      ]
    },
    {
      "comment": "System",
      "rules": [
        { "pattern": "sudo *", "action": "ask" },
        { "pattern": "dd *", "action": "ask" },
        { "pattern": "diskutil *", "action": "ask" },
        { "pattern": "shutdown*", "action": "ask" },
        { "pattern": "reboot*", "action": "ask" },
        { "pattern": "halt*", "action": "ask" },
        { "pattern": "crontab", "action": "ask" },
        { "pattern": "crontab *", "action": "ask" },
        { "pattern": "defaults delete *", "action": "ask" },
        { "pattern": "security", "action": "ask" },
        { "pattern": "security delete*", "action": "ask" }
      ]
    },
    {
      "comment": "Interpreter escape hatches",
      "rules": [
        { "pattern": "bash -c*", "action": "ask" },
        { "pattern": "bash * -c*", "action": "ask" },
        { "pattern": "sh -c*", "action": "ask" },
        { "pattern": "sh * -c*", "action": "ask" },
        { "pattern": "zsh -c*", "action": "ask" },
        { "pattern": "zsh * -c*", "action": "ask" },
        { "pattern": "eval *", "action": "ask" },
        { "pattern": "node -e*", "action": "ask" },
        { "pattern": "node --eval*", "action": "ask" },
        { "pattern": "node -p*", "action": "ask" },
        { "pattern": "node --print*", "action": "ask" },
        { "pattern": "python -c*", "action": "ask" },
        { "pattern": "python * -c*", "action": "ask" },
        { "pattern": "python3 -c*", "action": "ask" },
        { "pattern": "python3 * -c*", "action": "ask" },
        { "pattern": "ruby -e*", "action": "ask" },
        { "pattern": "perl -e*", "action": "ask" },
        { "pattern": "perl -E*", "action": "ask" },
        { "pattern": "swift -e*", "action": "ask" },
        { "pattern": "osascript*", "action": "ask" }
      ]
    }
  ]
}
