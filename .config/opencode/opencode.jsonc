{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-sol",
  "autoupdate": "notify",
  "experimental": {
    "openTelemetry": false
  },
  "share": "disabled",
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@1.5.0", "--autoConnect", "--no-usage-statistics"]
    },
    "cloudflare-api": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "uidotsh": {
      "type": "remote",
      "url": "https://ui.sh/mcp?agent=opencode",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:UIDOTSH_TOKEN}"
      }
    }
  },
  "permission": {
    "webfetch": "allow",
    "doom_loop": "ask",
    "external_directory": {
      "*": "ask",
      "~/.agents/**": "allow",
      "~/.claude/**": "allow",
      "~/.config/**": "allow",
      "~/projects/**": "allow"
    },
    "bash": {
      // BEGIN generated permissions (scripts/generate-permissions.mjs)
      // Default (allow)
      "*": "allow",
      // File deletion (ask)
      "rm *": "ask",
      "rm -rf *": "ask",
      "rsync --del*": "ask",
      "rsync * --del*": "ask",
      "find * -delete*": "ask",
      "find * -exec*": "ask",
      "find * -execdir*": "ask",
      "find * -ok*": "ask",
      "find * -okdir*": "ask",
      // In-place/bulk edits (ask)
      "sed -i*": "ask",
      "sed * -i*": "ask",
      "sed --in-place*": "ask",
      "sed * --in-place*": "ask",
      "xargs *": "ask",
      // Git working-tree discards (ask)
      "git checkout": "ask",
      "git checkout *": "ask",
      "git restore": "ask",
      "git restore *": "ask",
      "git switch --discard-changes*": "ask",
      "git switch * --discard-changes*": "ask",
      "git switch --force*": "ask",
      "git switch * --force*": "ask",
      "git clean": "ask",
      "git clean *": "ask",
      "git reset": "ask",
      "git reset *": "ask",
      "git stash drop*": "ask",
      "git stash clear*": "ask",
      "git worktree remove -f*": "ask",
      "git worktree remove --force*": "ask",
      "git worktree remove * -f*": "ask",
      "git worktree remove * --force*": "ask",
      // Git history rewriting (ask)
      "git rebase": "ask",
      "git rebase *": "ask",
      "git commit --amend*": "ask",
      "git commit * --amend*": "ask",
      "git filter-branch*": "ask",
      "git reflog expire*": "ask",
      "git gc --prune*": "ask",
      "git update-ref -d*": "ask",
      "git update-ref --stdin*": "ask",
      "git prune*": "ask",
      // Git branch/tag deletion (ask)
      "git branch -d *": "ask",
      "git branch -D *": "ask",
      "git branch -f*": "ask",
      "git branch -M *": "ask",
      "git branch --delete *": "ask",
      "git branch --delete --force *": "ask",
      "git branch --force*": "ask",
      "git tag -d *": "ask",
      "git tag --delete *": "ask",
      "git tag -f*": "ask",
      // Git push (ask)
      "git push": "ask",
      "git push *": "ask",
      "git -C * push*": "ask",
      "git -c * push*": "ask",
      // Git side effects (ask)
      "git diff --output*": "ask",
      "git diff * --output*": "ask",
      "git diff --ext-diff*": "ask",
      "git diff * --ext-diff*": "ask",
      "git config alias.*": "ask",
      "git config * alias.*": "ask",
      // Dependency changes (pnpm) (ask)
      "pnpm add*": "ask",
      "pnpm install*": "ask",
      "pnpm i": "ask",
      "pnpm i *": "ask",
      "pnpm remove*": "ask",
      "pnpm rm*": "ask",
      "pnpm uninstall*": "ask",
      "pnpm un*": "ask",
      "pnpm link*": "ask",
      "pnpm unlink*": "ask",
      "pnpm patch*": "ask",
      "pnpm patch-commit*": "ask",
      "pnpm import*": "ask",
      "pnpm rebuild*": "ask",
      "pnpm install-test*": "ask",
      "pnpm it*": "ask",
      "pnpm update*": "ask",
      "pnpm up*": "ask",
      "pnpm upgrade*": "ask",
      "pnpm fetch*": "ask",
      "pnpm create*": "ask",
      "pnpm dlx*": "ask",
      "pnpm publish*": "ask",
      "pnpm stage*": "ask",
      "pnpm deploy*": "ask",
      "pnpm approve-builds*": "ask",
      "pnpm self-update*": "ask",
      "pnpm store add*": "ask",
      "pnpm store prune*": "ask",
      "pnpm cache delete*": "ask",
      "pnpm config set*": "ask",
      "pnpm config delete*": "ask",
      "pnpm env add*": "ask",
      "pnpm env remove*": "ask",
      "pnpm env use*": "ask",
      "pnpm runtime add*": "ask",
      "pnpm runtime remove*": "ask",
      "pnpm runtime use*": "ask",
      "pnpm rt add*": "ask",
      "pnpm rt remove*": "ask",
      "pnpm rt use*": "ask",
      // Dependency changes (npm) (ask)
      "npm install*": "ask",
      "npm i": "ask",
      "npm i *": "ask",
      "npm add*": "ask",
      "npm ci*": "ask",
      "npm it*": "ask",
      "npm init *": "ask",
      "npm create*": "ask",
      "npm uninstall*": "ask",
      "npm remove*": "ask",
      "npm rm*": "ask",
      "npm un*": "ask",
      "npm update*": "ask",
      "npm up*": "ask",
      "npm link*": "ask",
      "npm unlink*": "ask",
      "npm publish*": "ask",
      "npm audit fix*": "ask",
      "npm exec*": "ask",
      "npx *": "ask",
      // Dependency changes (yarn) (ask)
      "yarn": "ask",
      "yarn install*": "ask",
      "yarn add*": "ask",
      "yarn create*": "ask",
      "yarn remove*": "ask",
      "yarn up*": "ask",
      "yarn dlx*": "ask",
      "yarn global*": "ask",
      "yarn link*": "ask",
      "yarn unlink*": "ask",
      "yarn publish*": "ask",
      "yarn npm publish*": "ask",
      "yarn set version*": "ask",
      // Dependency changes (Python/Ruby) (ask)
      "pip install*": "ask",
      "pip uninstall*": "ask",
      "pip3 install*": "ask",
      "pip3 uninstall*": "ask",
      "gem install*": "ask",
      "gem uninstall*": "ask",
      "gem update*": "ask",
      // Cloudflare Wrangler CLI (ask)
      "wrangler": "ask",
      "wrangler *": "ask",
      "pnpm exec wrangler*": "ask",
      // Remote state (GitHub) (ask)
      "gh issue close *": "ask",
      "gh pr close *": "ask",
      "gh pr create *": "ask",
      "gh pr edit *": "ask",
      "gh pr comment *": "ask",
      "gh pr review *": "ask",
      "gh pr ready *": "ask",
      "gh pr reopen *": "ask",
      "gh pr merge *": "ask",
      "gh repo delete *": "ask",
      "gh release delete*": "ask",
      "gh run cancel *": "ask",
      "gh run rerun *": "ask",
      "gh workflow run *": "ask",
      "gh workflow enable *": "ask",
      "gh workflow disable *": "ask",
      "gh api -X*": "ask",
      "gh api * -X*": "ask",
      "gh api --method*": "ask",
      "gh api * --method*": "ask",
      "gh api * -f*": "ask",
      "gh api * -F*": "ask",
      "gh api * --field*": "ask",
      "gh api * --raw-field*": "ask",
      "gh api * --input*": "ask",
      // Remote state (GitLab) (ask)
      "glab ci cancel *": "ask",
      "glab ci retry *": "ask",
      "glab ci run *": "ask",
      "glab issue close *": "ask",
      "glab mr close *": "ask",
      "glab mr create *": "ask",
      "glab mr update *": "ask",
      "glab mr note *": "ask",
      "glab mr approve *": "ask",
      "glab mr reopen *": "ask",
      "glab mr merge *": "ask",
      "glab repo delete *": "ask",
      "glab api -X*": "ask",
      "glab api * -X*": "ask",
      "glab api --method*": "ask",
      "glab api * --method*": "ask",
      // Homebrew (ask)
      "brew install *": "ask",
      "brew install --cask *": "ask",
      "brew reinstall *": "ask",
      "brew upgrade*": "ask",
      "brew tap *": "ask",
      "brew uninstall *": "ask",
      "brew remove *": "ask",
      "brew rm *": "ask",
      // System (ask)
      "sudo *": "ask",
      "dd *": "ask",
      "diskutil *": "ask",
      "shutdown*": "ask",
      "reboot*": "ask",
      "halt*": "ask",
      "crontab": "ask",
      "crontab *": "ask",
      "defaults delete *": "ask",
      "security": "ask",
      "security delete*": "ask",
      // Interpreter escape hatches (ask)
      "bash -c*": "ask",
      "bash * -c*": "ask",
      "sh -c*": "ask",
      "sh * -c*": "ask",
      "zsh -c*": "ask",
      "zsh * -c*": "ask",
      "eval *": "ask",
      "node -e*": "ask",
      "node --eval*": "ask",
      "node -p*": "ask",
      "node --print*": "ask",
      "python -c*": "ask",
      "python * -c*": "ask",
      "python3 -c*": "ask",
      "python3 * -c*": "ask",
      "ruby -e*": "ask",
      "perl -e*": "ask",
      "perl -E*": "ask",
      "swift -e*": "ask",
      "osascript*": "ask"
      // END generated permissions
    }
  }
}
