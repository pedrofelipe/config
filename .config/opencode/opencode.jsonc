{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "autoupdate": "notify",
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect", "--no-usage-statistics"]
    },
    "cloudflare-api": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "uidotsh": {
      "type": "remote",
      "url": "https://ui.sh/mcp?agent=opencode",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:UIDOTSH_TOKEN}"
      }
    }
  },
  "permission": {
    "webfetch": "allow",
    "doom_loop": "ask",
    "read": {
      "~/.claude/**": "allow",
      "~/.config/ghostty/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/projects/**": "allow",
      "**/*.env": "deny",
      "**/.env.*": "deny",
      "**/*.dev.vars": "deny",
      "**/*.env.example": "allow",
      "**/*.dev.vars.example": "allow"
    },
    "edit": {
      "~/.claude/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.config/ghostty/**": "allow",
      "~/projects/**": "allow",
      "**/*.env": "deny",
      "**/.env.*": "deny",
      "**/*.dev.vars": "deny"
    },
    "glob": {
      "~/.claude/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.config/ghostty/**": "allow",
      "~/projects/**": "allow",
      "**/*.env": "deny",
      "**/.env.*": "deny",
      "**/*.dev.vars": "deny",
      "**/*.env.example": "allow",
      "**/*.dev.vars.example": "allow"
    },
    "grep": {
      "~/.claude/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.config/ghostty/**": "allow",
      "~/projects/**": "allow",
      "**/*.env": "deny",
      "**/.env.*": "deny",
      "**/*.dev.vars": "deny",
      "**/*.env.example": "allow",
      "**/*.dev.vars.example": "allow"
    },
    "list": {
      "~/.claude/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.config/ghostty/**": "allow",
      "~/projects/**": "allow",
      "**/*.env": "deny",
      "**/.env.*": "deny",
      "**/*.dev.vars": "deny",
      "**/*.env.example": "allow",
      "**/*.dev.vars.example": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/.claude/**": "allow",
      "~/.config/ghostty/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/projects/**": "allow",
      "/tmp/**": "allow",
      "/private/tmp/**": "allow"
    },
    "bash": {
      "*": "ask",
      // Git
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch *": "allow",
      "git show *": "allow",
      "git stash list *": "allow",
      "git remote *": "allow",
      "git fetch *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git checkout *": "allow",
      "git switch *": "allow",
      "git merge *": "allow",
      "git clone *": "allow",
      "git pull *": "allow",
      "git init *": "allow",
      "git worktree *": "allow",
      "git rebase *": "ask",
      "git push *": "ask",
      "git reset --soft *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      // Text processing
      "sort *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "cut *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "tr *": "allow",
      "xargs *": "allow",
      "tee *": "allow",
      "diff *": "allow",
      "comm *": "allow",
      "paste *": "allow",
      "column *": "allow",
      // System info
      "which *": "allow",
      "type *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "env": "allow",
      "printenv *": "allow",
      "uname *": "allow",
      "hostname": "allow",
      "whoami": "allow",
      "id": "allow",
      "date *": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "mkdir *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "rm *": "ask",
      "rm -rf *": "ask",
      "pnpm *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "node *": "allow",
      "bun *": "allow",
      // Package scripts
      "pnpm lint": "allow",
      "pnpm lint *": "allow",
      "pnpm lint:*": "allow",
      "pnpm format": "allow",
      "pnpm format *": "allow",
      "pnpm format:*": "allow",
      "pnpm typecheck": "allow",
      "pnpm typecheck *": "allow",
      "pnpm typecheck:*": "allow",
      "pnpm test": "allow",
      "pnpm test *": "allow",
      "pnpm test:*": "allow",
      "pnpm check": "allow",
      "pnpm check *": "allow",
      "pnpm check:*": "allow",
      "pnpm run *": "allow",
      "pnpm --filter *": "allow",
      "pnpm -F *": "allow",
      "pnpm -r *": "allow",
      "pnpm --recursive *": "allow",
      "npm run *": "allow",
      "npm test": "allow",
      "npm test *": "allow",
      "npm lint": "allow",
      "npm lint *": "allow",
      "npm lint:*": "allow",
      "npm format": "allow",
      "npm format *": "allow",
      "npm format:*": "allow",
      "npm typecheck": "allow",
      "npm typecheck *": "allow",
      "yarn lint": "allow",
      "yarn lint *": "allow",
      "yarn lint:*": "allow",
      "yarn format": "allow",
      "yarn format *": "allow",
      "yarn format:*": "allow",
      "yarn typecheck": "allow",
      "yarn typecheck *": "allow",
      "yarn test": "allow",
      "yarn test *": "allow",
      "yarn test:*": "allow",
      "yarn check": "allow",
      "yarn check *": "allow",
      "yarn run *": "allow",
      // GitHub read
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "gh pr checks *": "allow",
      "gh pr status *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh issue status *": "allow",
      "gh repo view *": "allow",
      "gh repo clone *": "allow",
      "gh api *": "allow",
      "gh search *": "allow",
      "gh status": "allow",
      "gh status *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow",
      "gh run watch *": "allow",
      "gh workflow list *": "allow",
      "gh workflow view *": "allow",
      "gh cache list *": "allow",
      // GitHub metadata read
      "gh release list *": "allow",
      "gh release view *": "allow",
      "gh gist list *": "allow",
      "gh gist view *": "allow",
      "gh label list *": "allow",
      "gh ruleset list *": "allow",
      "gh ruleset view *": "allow",
      // GitHub writes
      "gh pr create *": "allow",
      "gh pr merge *": "ask",
      "gh pr close *": "ask",
      "gh issue create *": "allow",
      "gh issue close *": "ask",
      "gh run cancel *": "ask",
      "gh run rerun *": "ask",
      "gh release create *": "ask",
      "gh release delete *": "deny",
      "lsof *": "allow",
      "kill *": "ask",
      "wrangler *": "ask",
      // Dev utilities
      "jq *": "allow",
      "bat *": "allow",
      "fd *": "allow",
      "fzf *": "allow",
      "delta *": "allow",
      "tree *": "allow",
      "curl *": "allow",
      "wget *": "allow",
      "make *": "allow",
      // GitLab CLI
      "glab mr list *": "allow",
      "glab mr view *": "allow",
      "glab mr diff *": "allow",
      "glab mr checkout *": "allow",
      "glab issue list *": "allow",
      "glab issue view *": "allow",
      "glab repo view *": "allow",
      "glab auth *": "allow",
      "glab mr create *": "allow",
      "glab mr merge *": "ask",
      "glab mr close *": "ask",
      "glab issue create *": "allow",
      "glab issue close *": "ask",
      "mkcert *": "ask",
      "zoxide *": "allow",
      "atuin *": "allow",
      "cloudflared *": "ask",
      "yarn *": "allow",
      // macOS
      "brew *": "ask",
      "open *": "allow",
      "pbcopy": "allow",
      "pbpaste": "allow",
      "source *": "ask",
      // Hard denies
      "git reset --hard *": "deny",
      "git push --force *": "deny"
    }
  }
}
