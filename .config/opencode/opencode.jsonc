{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "autoupdate": "notify",
  "experimental": {
    "openTelemetry": false
  },
  "share": "disabled",
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect", "--no-usage-statistics"]
    },
    "cloudflare-api": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "uidotsh": {
      "type": "remote",
      "url": "https://ui.sh/mcp?agent=opencode",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:UIDOTSH_TOKEN}"
      }
    }
  },
  "permission": {
    "webfetch": "allow",
    "doom_loop": "ask",
    "external_directory": {
      "*": "ask",
      "~/.agents/**": "allow",
      "~/.claude/**": "allow",
      "~/.config/**": "allow",
      "~/projects/**": "allow"
    },
    "bash": {
      "*": "ask",
      // Shell utilities/navigation
      "atuin *": "allow",
      "exit *": "allow",
      "zoxide *": "allow",
      // Git
      "git add *": "allow",
      "git branch *": "allow",
      "git checkout *": "allow",
      "git clone *": "allow",
      "git commit *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git fetch *": "allow",
      "git grep*": "allow",
      "git init *": "allow",
      "git log *": "allow",
      "git merge *": "allow",
      "git pull *": "allow",
      "git push": "allow",
      "git push *": "allow",
      "git rebase": "allow",
      "git rebase *": "allow",
      "git remote *": "allow",
      "git reset --soft *": "allow",
      "git show *": "allow",
      "git stash list *": "allow",
      "git status*": "allow",
      "git switch *": "allow",
      "git worktree *": "allow",
      // File and search utilities
      "cat *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "tail *": "allow",
      // Text processing
      "awk *": "allow",
      "column *": "allow",
      "comm *": "allow",
      "cut *": "allow",
      "diff *": "allow",
      "paste *": "allow",
      "sed *": "allow",
      "sort *": "allow",
      "tee *": "allow",
      "tr *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "xargs *": "allow",
      // File operations
      "cp *": "allow",
      "mkdir *": "allow",
      "mktemp *": "allow",
      "mv *": "allow",
      "rm *": "ask",
      "rm -rf *": "ask",
      // System inspection
      "date *": "allow",
      "df *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "file *": "allow",
      "hostname": "allow",
      "id": "allow",
      "lsof *": "allow",
      "man *": "allow",
      "printf *": "allow",
      "pwd": "allow",
      "stat *": "allow",
      "type *": "allow",
      "uname *": "allow",
      "which *": "allow",
      "whoami": "allow",
      // JavaScript runtime
      "node *": "allow",
      // Package scripts
      "pnpm --filter *": "allow",
      "pnpm --recursive *": "allow",
      "pnpm -F *": "allow",
      "pnpm -r *": "allow",
      "pnpm check*": "allow",
      "pnpm format*": "allow",
      "pnpm i": "ask",
      "pnpm i *": "ask",
      "pnpm install*": "ask",
      "pnpm lint*": "allow",
      "pnpm run *": "allow",
      "pnpm test*": "allow",
      "pnpm typecheck*": "allow",
      // GitHub read
      "gh issue list *": "allow",
      "gh issue status *": "allow",
      "gh issue view *": "allow",
      "gh pr checkout *": "allow",
      "gh pr checks *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "gh pr status *": "allow",
      "gh pr view *": "allow",
      "gh repo clone *": "allow",
      "gh repo view *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow",
      "gh run watch *": "allow",
      "gh search *": "allow",
      "gh status*": "allow",
      // GitHub writes
      "gh issue close *": "ask",
      "gh issue create *": "allow",
      "gh pr close *": "ask",
      "gh pr create *": "allow",
      "gh pr merge *": "ask",
      "gh run cancel *": "ask",
      "gh run rerun *": "ask",
      // Dev utilities
      "bat *": "allow",
      "curl *": "allow",
      "delta *": "allow",
      "fd *": "allow",
      "fzf *": "allow",
      "jq *": "allow",
      "make *": "allow",
      "shellcheck *": "allow",
      "tree *": "allow",
      "wget *": "allow",
      // GitLab CLI
      "glab auth *": "allow",
      "glab ci cancel *": "ask",
      "glab ci list *": "allow",
      "glab ci retry *": "ask",
      "glab ci run *": "ask",
      "glab ci status *": "allow",
      "glab ci trace *": "allow",
      "glab ci view *": "allow",
      "glab issue close *": "ask",
      "glab issue create *": "allow",
      "glab issue list *": "allow",
      "glab issue view *": "allow",
      "glab mr checkout *": "allow",
      "glab mr close *": "ask",
      "glab mr create *": "allow",
      "glab mr diff *": "allow",
      "glab mr list *": "allow",
      "glab mr merge *": "ask",
      "glab mr view *": "allow",
      "glab repo clone *": "allow",
      "glab repo view *": "allow",
      "glab search *": "allow",
      // macOS
      "ghostty *": "allow",
      "open *": "allow",
      "pbcopy": "allow",
      "pbpaste": "allow",
      // Destructive Git operations
      "git push * +*": "ask",
      "git push * --mirror*": "ask",
      "git push * -f*": "ask",
      "git push *--force*": "ask",
      "git push +*": "ask",
      "git push --mirror*": "ask",
      "git push -f*": "ask",
      "git reset --hard*": "ask"
    }
  }
}
