{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-sol",
  "autoupdate": "notify",
  "experimental": {
    "openTelemetry": false
  },
  "share": "disabled",
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@1.5.0", "--autoConnect", "--no-usage-statistics"]
    },
    "cloudflare-api": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "uidotsh": {
      "type": "remote",
      "url": "https://ui.sh/mcp?agent=opencode",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:UIDOTSH_TOKEN}"
      }
    }
  },
  "permission": {
    "webfetch": "allow",
    "doom_loop": "ask",
    "external_directory": {
      "*": "ask",
      "~/.agents/**": "allow",
      "~/.claude/**": "allow",
      "~/.config/**": "allow",
      "~/projects/**": "allow"
    },
    "bash": {
      "*": "ask",
      // BEGIN generated permissions (scripts/generate-permissions.mjs)
      // Shell utilities/navigation (allow)
      "atuin *": "allow",
      "exit *": "allow",
      "zoxide *": "allow",
      // Git (allow)
      "git *": "allow",
      // File and search utilities (allow)
      "cat *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "tail *": "allow",
      // Text processing (allow)
      "awk *": "allow",
      "column *": "allow",
      "comm *": "allow",
      "cut *": "allow",
      "diff *": "allow",
      "paste *": "allow",
      "sed *": "allow",
      "sort *": "allow",
      "tee *": "allow",
      "tr *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      // File operations (allow)
      "cp *": "allow",
      "mkdir *": "allow",
      "mktemp *": "allow",
      "mv *": "allow",
      // System inspection (allow)
      "date *": "allow",
      "df *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "file *": "allow",
      "hostname": "allow",
      "id": "allow",
      "lsof": "allow",
      "lsof *": "allow",
      "man *": "allow",
      "pgrep": "allow",
      "pgrep *": "allow",
      "printf *": "allow",
      "ps": "allow",
      "ps *": "allow",
      "pwd": "allow",
      "stat *": "allow",
      "type *": "allow",
      "uname *": "allow",
      "which *": "allow",
      "whoami": "allow",
      // Process control (allow)
      "kill *": "allow",
      "killall *": "allow",
      "pkill *": "allow",
      // JavaScript runtime (allow)
      "node *": "allow",
      // Package manager (allow)
      "pnpm *": "allow",
      // GitHub read (allow)
      "gh issue list *": "allow",
      "gh issue status *": "allow",
      "gh issue view *": "allow",
      "gh pr checkout *": "allow",
      "gh pr checks *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "gh pr status *": "allow",
      "gh pr view *": "allow",
      "gh repo clone *": "allow",
      "gh repo view *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow",
      "gh run watch *": "allow",
      "gh search *": "allow",
      "gh status*": "allow",
      // GitHub writes (allow)
      "gh issue create *": "allow",
      "gh pr create *": "allow",
      // Dev utilities (allow)
      "bat *": "allow",
      "curl *": "allow",
      "delta *": "allow",
      "fd *": "allow",
      "fzf *": "allow",
      "jq *": "allow",
      "make *": "allow",
      "shellcheck *": "allow",
      "tree *": "allow",
      "wget *": "allow",
      // GitLab CLI (allow)
      "glab auth *": "allow",
      "glab ci list *": "allow",
      "glab ci status *": "allow",
      "glab ci trace *": "allow",
      "glab ci view *": "allow",
      "glab issue create *": "allow",
      "glab issue list *": "allow",
      "glab issue view *": "allow",
      "glab mr checkout *": "allow",
      "glab mr create *": "allow",
      "glab mr diff *": "allow",
      "glab mr list *": "allow",
      "glab mr view *": "allow",
      "glab repo clone *": "allow",
      "glab repo view *": "allow",
      "glab search *": "allow",
      // macOS (allow)
      "ghostty *": "allow",
      "open *": "allow",
      "pbcopy": "allow",
      "pbpaste": "allow",
      // File and search utilities (ask)
      "find * -delete*": "ask",
      "find * -exec*": "ask",
      "find * -execdir*": "ask",
      "find * -ok*": "ask",
      "find * -okdir*": "ask",
      // Text processing (ask)
      "sed -i*": "ask",
      "sed * -i*": "ask",
      "sed --in-place*": "ask",
      "sed * --in-place*": "ask",
      "xargs *": "ask",
      // File operations (ask)
      "rm *": "ask",
      "rm -rf *": "ask",
      // Package manager (ask)
      "pnpm add*": "ask",
      "pnpm install*": "ask",
      "pnpm i": "ask",
      "pnpm i *": "ask",
      "pnpm remove*": "ask",
      "pnpm rm*": "ask",
      "pnpm uninstall*": "ask",
      "pnpm un*": "ask",
      "pnpm exec*": "ask",
      "pnpm link*": "ask",
      "pnpm unlink*": "ask",
      "pnpm patch*": "ask",
      "pnpm import*": "ask",
      "pnpm rebuild*": "ask",
      "pnpm patch-commit*": "ask",
      "pnpm install-test*": "ask",
      "pnpm it*": "ask",
      "pnpm update*": "ask",
      "pnpm up*": "ask",
      "pnpm upgrade*": "ask",
      "pnpm fetch*": "ask",
      "pnpm create*": "ask",
      "pnpm dlx*": "ask",
      "pnpm publish*": "ask",
      "pnpm stage*": "ask",
      "pnpm deploy*": "ask",
      "pnpm approve-builds*": "ask",
      "pnpm self-update*": "ask",
      "pnpm store add*": "ask",
      "pnpm store prune*": "ask",
      "pnpm cache delete*": "ask",
      "pnpm config set*": "ask",
      "pnpm config delete*": "ask",
      "pnpm env add*": "ask",
      "pnpm env remove*": "ask",
      "pnpm env use*": "ask",
      "pnpm runtime add*": "ask",
      "pnpm runtime remove*": "ask",
      "pnpm runtime use*": "ask",
      "pnpm rt add*": "ask",
      "pnpm rt remove*": "ask",
      "pnpm rt use*": "ask",
      // GitHub writes (ask)
      "gh issue close *": "ask",
      "gh pr close *": "ask",
      "gh pr merge *": "ask",
      "gh run cancel *": "ask",
      "gh run rerun *": "ask",
      // GitLab CLI (ask)
      "glab ci cancel *": "ask",
      "glab ci retry *": "ask",
      "glab ci run *": "ask",
      "glab issue close *": "ask",
      "glab mr close *": "ask",
      "glab mr merge *": "ask",
      // Risky Git operations (ask)
      "git stash": "ask",
      "git stash *": "ask",
      "git rebase": "ask",
      "git rebase *": "ask",
      "git clean": "ask",
      "git clean *": "ask",
      "git reset": "ask",
      "git reset *": "ask",
      "git restore": "ask",
      "git restore *": "ask",
      "git switch --discard-changes*": "ask",
      "git switch * --discard-changes*": "ask",
      "git switch --force*": "ask",
      "git switch * --force*": "ask",
      "git checkout": "ask",
      "git checkout *": "ask",
      "git branch -d *": "ask",
      "git branch -D *": "ask",
      "git branch -f*": "ask",
      "git branch -M *": "ask",
      "git branch --delete *": "ask",
      "git branch --delete --force *": "ask",
      "git branch --force*": "ask",
      "git commit --amend*": "ask",
      "git commit * --amend*": "ask",
      "git diff --output*": "ask",
      "git diff * --output*": "ask",
      "git diff --ext-diff*": "ask",
      "git diff * --ext-diff*": "ask",
      "git push * +*": "ask",
      "git push * --delete *": "ask",
      "git push * --mirror*": "ask",
      "git push * -f*": "ask",
      "git push * --force*": "ask",
      "git push *--force*": "ask",
      "git push * :*": "ask",
      "git push :*": "ask",
      "git push +*": "ask",
      "git push --delete *": "ask",
      "git push --mirror*": "ask",
      "git push --force*": "ask",
      "git push -f*": "ask",
      "git reflog expire*": "ask",
      "git gc --prune*": "ask",
      "git filter-branch*": "ask",
      "git update-ref -d*": "ask",
      "git update-ref --stdin*": "ask",
      "git prune*": "ask",
      // Homebrew (ask)
      "brew install *": "ask",
      "brew install --cask *": "ask"
      // END generated permissions
    }
  }
}
