{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DO_NOT_TRACK": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(*)",

      "Read(~/.claude/**)",
      "Read(~/.config/**)",
      "Read(~/projects/**)",
      "Edit(~/.claude/**)",
      "Edit(~/.config/**)",
      "Edit(~/projects/**)",
      "Write(~/.claude/**)",
      "Write(~/.config/**)",
      "Write(~/projects/**)",

      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git stash list *)",
      "Bash(git remote *)",
      "Bash(git fetch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git clone *)",
      "Bash(git pull *)",
      "Bash(git init *)",
      "Bash(git worktree *)",
      "Bash(git reset --soft *)",

      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(grep *)",

      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(cut *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(tr *)",
      "Bash(xargs *)",
      "Bash(tee *)",
      "Bash(diff *)",
      "Bash(comm *)",
      "Bash(paste *)",
      "Bash(column *)",

      "Bash(which *)",
      "Bash(type *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(uname *)",
      "Bash(hostname)",
      "Bash(whoami)",
      "Bash(id)",
      "Bash(date *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",

      "Bash(node *)",

      "Bash(pnpm lint*)",
      "Bash(pnpm format*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm test*)",
      "Bash(pnpm check*)",
      "Bash(pnpm run *)",
      "Bash(pnpm --filter *)",
      "Bash(pnpm -F *)",
      "Bash(pnpm -r *)",
      "Bash(pnpm --recursive *)",

      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checkout *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue status *)",
      "Bash(gh repo view *)",
      "Bash(gh repo clone *)",
      "Bash(gh search *)",
      "Bash(gh status)",
      "Bash(gh status *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh pr create *)",
      "Bash(gh issue create *)",

      "Bash(lsof *)",

      "Bash(jq *)",
      "Bash(bat *)",
      "Bash(fd *)",
      "Bash(fzf *)",
      "Bash(delta *)",
      "Bash(tree *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(make *)",

      "Bash(glab mr list *)",
      "Bash(glab mr view *)",
      "Bash(glab mr diff *)",
      "Bash(glab mr checkout *)",
      "Bash(glab issue list *)",
      "Bash(glab issue view *)",
      "Bash(glab repo view *)",
      "Bash(glab repo clone *)",
      "Bash(glab ci list *)",
      "Bash(glab ci view *)",
      "Bash(glab ci status *)",
      "Bash(glab ci trace *)",
      "Bash(glab auth *)",
      "Bash(glab search *)",
      "Bash(glab mr create *)",
      "Bash(glab issue create *)",

      "Bash(zoxide *)",
      "Bash(atuin *)",

      "Bash(open *)",
      "Bash(pbcopy)",
      "Bash(pbpaste)"
    ],
    "ask": [
      "Bash(git rebase *)",
      "Bash(git push *)",

      "Bash(rm *)",
      "Bash(rm -rf *)",

      "Bash(pnpm install)",
      "Bash(pnpm install *)",
      "Bash(pnpm i)",
      "Bash(pnpm i *)",

      "Bash(gh pr merge *)",
      "Bash(gh pr close *)",
      "Bash(gh issue close *)",
      "Bash(gh run cancel *)",
      "Bash(gh run rerun *)",

      "Bash(glab mr merge *)",
      "Bash(glab mr close *)",
      "Bash(glab issue close *)",
      "Bash(glab ci cancel *)",
      "Bash(glab ci retry *)",
      "Bash(glab ci run *)",

      "Bash(git reset --hard*)",
      "Bash(git push *--force*)",
      "Bash(git push -f*)",
      "Bash(git push * -f*)"
    ],
    "additionalDirectories": [
      "~/.claude",
      "~/.config",
      "~/projects"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // \"\"'); if echo \"$cmd\" | grep -q 'ssh-keygen'; then echo '{\"continue\": false, \"stopReason\": \"SSH key creation requires your confirmation. To proceed, explicitly ask me to create SSH keys.\"}'; fi",
            "statusMessage": "Checking for SSH key operations..."
          },
          {
            "type": "command",
            "command": "input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // \"\"'); if echo \"$cmd\" | grep -qE 'brew install'; then echo '{\"continue\": false, \"stopReason\": \"Package installation requires your confirmation. To proceed, explicitly ask me to install the package.\"}'; fi",
            "statusMessage": "Checking for brew installs..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "cloudflare@cloudflare": true
  },
  "extraKnownMarketplaces": {
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      }
    }
  },
  "effortLevel": "xhigh",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
