{
  "[javascript][json][typescript][typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "claudeCode.preferredLocation": "panel",
  "debug.internalConsoleOptions": "neverOpen",
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "editor.detectIndentation": false,
  "editor.fontFamily": "'Fira Code'",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.formatOnPaste": false,
  "editor.formatOnSave": true,
  "editor.inlineSuggest.enabled": true,
  "editor.insertSpaces": true,
  "editor.minimap.enabled": false,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.parameterHints.enabled": false,
  "editor.stickyScroll.enabled": true,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.suggestSelection": "first",
  "editor.tabSize": 2,
  "editor.unicodeHighlight.nonBasicASCII": false,
  "explorer.compactFolders": false,
  "explorer.confirmDelete": true,
  "explorer.confirmDragAndDrop": true,
  "extensions.ignoreRecommendations": true,
  "files.exclude": {
    "**/.yarn": true
  },
  "gitlens.ai.enabled": false,
  "gitlens.advanced.skipOnboarding": true,
  "gitlens.cloudIntegrations.enabled": false,
  "gitlens.codeLens.enabled": false,
  "gitlens.currentLine.enabled": true,
  "gitlens.graph.minimap.enabled": false,
  "gitlens.graph.statusBar.enabled": false,
  "gitlens.hovers.enabled": false,
  "gitlens.integrations.enabled": false,
  "gitlens.showWhatsNewAfterUpgrades": false,
  "gitlens.statusBar.enabled": true,
  "gitlens.telemetry.enabled": false,
  "js/ts.suggest.autoImports": false,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "search.sortOrder": "modified",
  "security.workspace.trust.enabled": false,
  "sortLines.filterBlankLines": true,
  "telemetry.telemetryLevel": "off",
  "workbench.colorTheme": "GitHub Dark Default",
  "workbench.editor.labelFormat": "medium",
  "workbench.iconTheme": "city-lights-icons-vsc",
  "workbench.startupEditor": "newUntitledFile",
  "workbench.tree.indent": 5,
  "workbench.tree.renderIndentGuides": "always",
}